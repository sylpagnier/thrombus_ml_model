# Large / generated data (never push) — ignore contents, not the dir itself,
# so we can carve out small public reference manifests.
data/*
!data/reference/
!data/reference/**
# Sweep / ablation leftovers stay local
data/reference_local/

# Generated training / eval artifacts (local runs)
outputs/

# Heavy COMSOL sources
comsol_models/

# Customer inbox uploads (keep README only)
customer_geometries/*
!customer_geometries/README.txt

# Local notes scratchpad
notes/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
env/
venv/
ENV/
.venv/

# Checkpoints / tensors if ever dropped outside outputs/
*.pth
*.pt
*.ckpt
!customer_geometries/README.txt

# COMSOL / mesh binaries if ever outside comsol_models/
*.mph
*.nas
*.msh

# IDE / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Root junk / local dumps (never re-add)
/test_legend.png
/test_legend.json
/check_nodes_out.txt
*.log
